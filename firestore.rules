rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.userId == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 512));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']);
    }

    // --- FF Account Validation ---
    function isValidFFAccount(data) {
      return data.userId == request.auth.uid
        && data.playerId is string && data.playerId.size() <= 32
        && data.region is string && data.region.size() <= 64
        && (data.nickname == null || (data.nickname is string && data.nickname.size() <= 64))
        && (data.level == null || (data.level is number && data.level >= 1 && data.level <= 100));
    }

    match /ff_accounts/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidFFAccount(incoming()) && incoming().linkedAt == request.time;
      allow update: if isOwner(userId) && isValidFFAccount(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['nickname', 'level', 'rank', 'region']);
      allow delete: if isOwner(userId);
    }
  }
}
